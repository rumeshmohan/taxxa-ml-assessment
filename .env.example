# taxxa_assessment/.env.example
# Copy to .env and fill in your keys.
# Active provider is set in config/params.yaml → active_generator.provider

# ── API Keys ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here
OPENAI_API_KEY=your_openai_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# Optional: custom base URLs (defaults already set in utils/config.py)
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Data ──────────────────────────────────────────────────────────────────────
# Root folder containing skatdk/, erhvervsstyrelsen/, retsinformation/, kila/
# Default: ./data  (relative to project root)
# DATA_DIR=/mnt/data

# ── Part 1 toggles ───────────────────────────────────────────────────────────
# SKIP_GENERATION=1   # skip LLM answer generation (retrieval metrics only)
# SKIP_RAGAS=1        # skip Ollama RAGAS scoring (faster dev iteration)

# ── Part 2 toggles ───────────────────────────────────────────────────────────
# RESUME_TRAIN=4393   # resume data prep from chunk index N (after crash)
# RESUME_VAL=463      # resume val generation from chunk index N
# DRY_RUN=1           # process only 3 chunks (sanity check)
# ADAPTER_PATH=part2_fine_tuning/outputs/kila-adapter/final_adapter
